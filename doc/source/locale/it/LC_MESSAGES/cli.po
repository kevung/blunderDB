msgstr "``--file`` — File di output (obbligatorio)."

#: ../../source/cli.rst:158
msgid "``--analysis`` — Inclure les analyses (défaut: oui)."
msgstr "``--analysis`` — Includere le analisi (predefinito: sì)."

#: ../../source/cli.rst:159
msgid "``--comments`` — Inclure les commentaires (défaut: oui)."
msgstr "``--comments`` — Includere i commenti (predefinito: sì)."

#: ../../source/cli.rst:160
msgid "``--filters`` — Inclure la bibliothèque de filtres (défaut: oui)."
msgstr "``--filters`` — Includere la libreria di filtri (predefinito: sì)."

#: ../../source/cli.rst:161
msgid "``--played-moves`` — Inclure les coups joués (défaut: oui)."
msgstr "``--played-moves`` — Includere le mosse giocate (predefinito: sì)."

#: ../../source/cli.rst:162
msgid "``--matches`` — Inclure les matchs (défaut: oui)."
msgstr "``--matches`` — Includere i match (predefinito: sì)."


#: ../../source/cli.rst:288
msgid "``--output`` — Fichier de sortie (défaut: sortie standard)."
msgstr "``--output`` — File di output (predefinito: output standard)."

#: ../../source/cli.rst:304
msgid "info — Métadonnées de la base"
msgstr "info — Metadati del database"

#: ../../source/cli.rst:306
msgid "Affiche les métadonnées et les statistiques d'une base de données."
msgstr "Mostra i metadati e le statistiche di un database."

#: ../../source/cli.rst:315
msgid "``--format`` — Format de sortie: ``text`` ou ``json`` (défaut: ``text``)."
msgstr ""
"``--format`` — Formato di output: ``text`` o ``json`` (predefinito: "
"``text``)."

#: ../../source/cli.rst:328
msgid "edit — Modifier les métadonnées"
msgstr "edit — Modificare i metadati"

#: ../../source/cli.rst:330
msgid "Modifie le nom d'utilisateur ou la description d'une base de données."
msgstr "Modifica il nome utente o la descrizione di un database."

#: ../../source/cli.rst:339
msgid "``--user`` — Nouveau nom d'utilisateur."
msgstr "``--user`` — Nuovo nome utente."

#: ../../source/cli.rst:340
msgid "``--description`` — Nouvelle description."
msgstr "``--description`` — Nuova descrizione."

#: ../../source/cli.rst:341
msgid "``--clear-user`` — Effacer le nom d'utilisateur."
msgstr "``--clear-user`` — Cancellare il nome utente."

#: ../../source/cli.rst:342
msgid "``--clear-description`` — Effacer la description."
msgstr "``--clear-description`` — Cancellare la descrizione."

#: ../../source/cli.rst:344
msgid "Au moins une option de modification est requise."
msgstr "È richiesta almeno un'opzione di modifica."

#: ../../source/cli.rst:357
msgid "verify — Vérifier l'intégrité"
msgstr "verify — Verificare l'integrità"

#: ../../source/cli.rst:359
msgid ""
"Vérifie l'intégrité de la base de données et, optionnellement, compare un"
" match avec son fichier source."
msgstr ""
"Verifica l'integrità del database e, facoltativamente, confronta un match"
" con il suo file di origine."

#: ../../source/cli.rst:369
msgid "``--match`` — ID du match à vérifier."
msgstr "``--match`` — ID del match da verificare."

#: ../../source/cli.rst:370
msgid "``--mat`` — Fichier MAT à comparer (utilisé avec ``--match``)."
msgstr "``--mat`` — File MAT da confrontare (usato con ``--match``)."

#: ../../source/cli.rst:372
msgid ""
"Sans l'option ``--match``, la commande affiche les statistiques générales"
" de la base. Avec ``--match``, elle vérifie les données du match et peut "
"les comparer avec le fichier source original."
msgstr ""
"Senza l'opzione ``--match``, il comando mostra le statistiche generali "
"del database. Con ``--match``, verifica i dati del match e può "
"confrontarli con il file di origine originale."

#: ../../source/cli.rst:390
msgid "delete — Supprimer des données"
msgstr "delete — Eliminare dati"

#: ../../source/cli.rst:392
msgid ""
"Supprime un match et toutes les données associées (parties, coups, "
"analyses)."
msgstr "Elimina un match e tutti i dati associati (partite, mosse, analisi)."

#: ../../source/cli.rst:401
msgid "``--type`` — Type de suppression: ``match`` (obligatoire)."
msgstr "``--type`` — Tipo di eliminazione: ``match`` (obbligatorio)."

#: ../../source/cli.rst:402
msgid "``--id`` — ID de l'élément à supprimer (obligatoire)."
msgstr "``--id`` — ID dell'elemento da eliminare (obbligatorio)."

#: ../../source/cli.rst:403
msgid "``--confirm`` — Supprimer sans demander de confirmation."
msgstr "``--confirm`` — Eliminare senza chiedere conferma."


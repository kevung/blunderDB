#: ../../source/cli.rst:192 ../../source/cli.rst:267 ../../source/cli.rst:296
#: ../../source/cli.rst:320 ../../source/cli.rst:350 ../../source/cli.rst:382
msgid "``--db`` — Base de données (obligatoire)."
msgstr "``--db`` — Database (required)."


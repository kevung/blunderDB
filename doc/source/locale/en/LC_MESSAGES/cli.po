msgid ""
"Chaque commande accepte l'option ``--help`` pour afficher son aide détaillée."
msgstr ""
"Each command accepts the ``--help`` option to display its detailed help."

#: ../../source/cli.rst:62
msgid "create — Créer une base de données"
msgstr "create — Create a database"

#: ../../source/cli.rst:64
msgid "Crée un nouveau fichier de base de données avec des métadonnées optionnelles."
msgstr "Create a new database file with optional metadata."

#: ../../source/cli.rst:70
msgid "**Options:**"
msgstr "**Options:**"

#: ../../source/cli.rst:72
msgid ""
"``--db`` — Chemin du fichier de base de données à créer (obligatoire)."
msgstr ""
"``--db`` — Path to the database file to create (required)."

#: ../../source/cli.rst:73
msgid "``--user`` — Nom du propriétaire de la base."
msgstr "``--user`` — Database owner name."

#: ../../source/cli.rst:74
msgid "``--description`` — Description de la base."
msgstr "``--description`` — Database description."

#: ../../source/cli.rst:75
msgid "``--force`` — Écraser le fichier s'il existe déjà."
msgstr "``--force`` — Overwrite the file if it already exists."

#: ../../source/cli.rst:77
msgid ""
"L'extension ``.db`` est ajoutée automatiquement si elle est absente. Les "
"répertoires parents sont créés si nécessaire."
msgstr ""
"The ``.db`` extension is added automatically if missing. Parent directories "
"are created as needed."

#: ../../source/cli.rst:80
msgid "**Exemple:**"
msgstr "**Example:**"

#: ../../source/cli.rst:86
msgid "import — Importer des données"
msgstr "import — Import data"

#: ../../source/cli.rst:88
msgid "Importe des fichiers de matchs ou de positions dans la base de données."
msgstr "Import match or position files into the database."

#: ../../source/cli.rst:94
msgid "``--db`` — Chemin de la base de données (obligatoire)."
msgstr "``--db`` — Path to the database (required)."

#: ../../source/cli.rst:95
msgid ""
"``--type`` — Type d'import: ``match``, ``position`` ou ``batch`` (obligatoire)."
msgstr ""
"``--type`` — Import type: ``match``, ``position`` or ``batch`` (required)."

#: ../../source/cli.rst:96
msgid "``--file`` — Fichier à importer (pour ``match`` et ``position``)."
msgstr "``--file`` — File to import (for ``match`` and ``position``)."

#: ../../source/cli.rst:97
msgid "``--dir`` — Répertoire à importer (pour ``batch``)."
msgstr "``--dir`` — Directory to import (for ``batch``)."

#: ../../source/cli.rst:98
msgid ""
"``--recursive`` — Scanner récursivement les sous-répertoires (défaut: oui)."
msgstr ""
"``--recursive`` — Recursively scan subdirectories (default: yes)."

#: ../../source/cli.rst:100
msgid "Import d'un match"
msgstr "Import a match"

#: ../../source/cli.rst:102
msgid ""
"Formats supportés: eXtreme Gammon (``.xg``, ``.xgp``), GNUbg (``.sgf``), "
"Jellyfish (``.mat``, ``.txt``) et BGBlitz (``.bgf``)."
msgstr ""
"Supported formats: eXtreme Gammon (``.xg``, ``.xgp``), GNUbg (``.sgf``), "
"Jellyfish (``.mat``, ``.txt``) and BGBlitz (``.bgf``)."

#: ../../source/cli.rst:109
msgid "Import de positions"
msgstr "Import positions"

#: ../../source/cli.rst:111
msgid "Importe des positions depuis un fichier texte (une position JSON par ligne):"
msgstr "Import positions from a text file (one JSON position per line):"

#: ../../source/cli.rst:117
msgid "Import par lot"
msgstr "Batch import"

#: ../../source/cli.rst:119
msgid ""
"Importe tous les fichiers de matchs d'un répertoire en une seule opération. "
"C'est la méthode la plus efficace pour importer un grand nombre de matchs."
msgstr ""
"Import all match files from a directory in a single operation. This is the "
"most efficient method for importing a large number of matches."

#: ../../source/cli.rst:128
msgid ""
"Un tableau récapitulatif indique pour chaque fichier si l'import a réussi "
"(✓), échoué (✗) ou s'il s'agit d'un doublon (⊘)."
msgstr ""
"A summary table shows for each file whether the import succeeded (✓), "
"failed (✗) or was a duplicate (⊘)."

#: ../../source/cli.rst:131
msgid "export — Exporter des données"
msgstr "export — Export data"

#: ../../source/cli.rst:133
msgid "Exporte le contenu de la base vers des fichiers."
msgstr "Export database contents to files."

#: ../../source/cli.rst:139
msgid "``--db`` — Base source (obligatoire)."
msgstr "``--db`` — Source database (required)."

#: ../../source/cli.rst:140
msgid ""
"``--type`` — Type d'export: ``database``, ``positions`` ou ``matches`` "
"(obligatoire)."
msgstr ""
"``--type`` — Export type: ``database``, ``positions`` or ``matches`` "
"(required)."

#: ../../source/cli.rst:141
msgid "``--file`` — Fichier de sortie (obligatoire)."
msgstr "``--file`` — Output file (required)."

#: ../../source/cli.rst:142
msgid "``--analysis`` — Inclure les analyses (défaut: oui)."
msgstr "``--analysis`` — Include analysis (default: yes)."

#: ../../source/cli.rst:143
msgid "``--comments`` — Inclure les commentaires (défaut: oui)."
msgstr "``--comments`` — Include comments (default: yes)."

#: ../../source/cli.rst:144
msgid "``--filters`` — Inclure la bibliothèque de filtres (défaut: oui)."
msgstr "``--filters`` — Include filter library (default: yes)."

#: ../../source/cli.rst:145
msgid "``--played-moves`` — Inclure les coups joués (défaut: oui)."
msgstr "``--played-moves`` — Include played moves (default: yes)."

#: ../../source/cli.rst:146
msgid "``--matches`` — Inclure les matchs (défaut: oui)."
msgstr "``--matches`` — Include matches (default: yes)."

#: ../../source/cli.rst:147
msgid "``--collections`` — Inclure les collections (défaut: non)."
msgstr "``--collections`` — Include collections (default: no)."

#: ../../source/cli.rst:148
msgid ""
"``--collection-ids`` — IDs de collections à exporter (séparés par des "
"virgules)."
msgstr ""
"``--collection-ids`` — Collection IDs to export (comma-separated)."

#: ../../source/cli.rst:149
msgid ""
"``--match-ids`` — IDs de matchs à exporter (séparés par des virgules, "
"vide = tous)."
msgstr ""
"``--match-ids`` — Match IDs to export (comma-separated, empty = all)."

#: ../../source/cli.rst:150
msgid ""
"``--tournament-ids`` — IDs de tournois à exporter (séparés par des virgules)."
msgstr ""
"``--tournament-ids`` — Tournament IDs to export (comma-separated)."

#: ../../source/cli.rst:152
msgid "**Exemples:**"
msgstr "**Examples:**"

#: ../../source/cli.rst:166
msgid "search — Rechercher des positions"
msgstr "search — Search positions"

#: ../../source/cli.rst:168
msgid "Recherche des positions dans la base selon des critères combinables."
msgstr "Search positions in the database using combinable criteria."

#: ../../source/cli.rst:174
msgid "**Options principales:**"
msgstr "**Main options:**"

#: ../../source/cli.rst:176
msgid "``--db`` — Base de données (obligatoire)."
msgstr "``--db`` — Database (required)."

#: ../../source/cli.rst:177
msgid ""
"``--format`` — Format de sortie: ``table``, ``json`` ou ``xgid`` "
"(défaut: ``table``)."
msgstr ""
"``--format`` — Output format: ``table``, ``json`` or ``xgid`` "
"(default: ``table``)."

#: ../../source/cli.rst:178
msgid "``--limit`` — Nombre maximum de résultats (0 = illimité)."
msgstr "``--limit`` — Maximum number of results (0 = unlimited)."

#: ../../source/cli.rst:179
msgid "``--export`` — Exporter les résultats vers une nouvelle base."
msgstr "``--export`` — Export results to a new database."

#: ../../source/cli.rst:181
msgid "**Filtres disponibles:**"
msgstr "**Available filters:**"

#: ../../source/cli.rst:183
msgid "``--decision`` — Type de décision: ``checker`` ou ``cube``."
msgstr "``--decision`` — Decision type: ``checker`` or ``cube``."

#: ../../source/cli.rst:184
msgid "``--pip-min`` / ``--pip-max`` — Intervalle de différence de pip count."
msgstr "``--pip-min`` / ``--pip-max`` — Pip count difference range."

#: ../../source/cli.rst:185
msgid "``--winrate-min`` / ``--winrate-max`` — Intervalle de taux de victoire (%)."
msgstr "``--winrate-min`` / ``--winrate-max`` — Win rate range (%)."

#: ../../source/cli.rst:186
msgid "``--cube`` — Valeur du videau."
msgstr "``--cube`` — Cube value."

#: ../../source/cli.rst:187
msgid "``--score1`` / ``--score2`` — Scores des joueurs."
msgstr "``--score1`` / ``--score2`` — Player scores."

#: ../../source/cli.rst:188
msgid "``--match-length`` — Longueur du match."
msgstr "``--match-length`` — Match length."

#: ../../source/cli.rst:189
msgid "``--error-min`` — Erreur d'équité minimale."
msgstr "``--error-min`` — Minimum equity error."

#: ../../source/cli.rst:190
msgid ""
"``--move-error-min`` / ``--move-error-max`` — Erreur du coup joué "
"(millipoints)."
msgstr ""
"``--move-error-min`` / ``--move-error-max`` — Played move error "
"(millipoints)."

#: ../../source/cli.rst:191
msgid "``--has-analysis`` — Uniquement les positions avec analyse."
msgstr "``--has-analysis`` — Only positions with analysis."

#: ../../source/cli.rst:192
msgid "``--off1-min`` / ``--off2-min`` — Pions sortis minimum (joueur 1/2)."
msgstr "``--off1-min`` / ``--off2-min`` — Minimum checkers off (player 1/2)."

#: ../../source/cli.rst:193
msgid ""
"``--match-ids`` — Filtrer par IDs de matchs (séparés par des virgules)."
msgstr ""
"``--match-ids`` — Filter by match IDs (comma-separated)."

#: ../../source/cli.rst:194
msgid ""
"``--tournament-ids`` — Filtrer par IDs de tournois (séparés par des virgules)."
msgstr ""
"``--tournament-ids`` — Filter by tournament IDs (comma-separated)."

#: ../../source/cli.rst:214
msgid "list — Lister le contenu"
msgstr "list — List contents"

#: ../../source/cli.rst:216
msgid "Affiche le contenu de la base de données."
msgstr "Display database contents."

#: ../../source/cli.rst:222
msgid "**Types:**"
msgstr "**Types:**"

#: ../../source/cli.rst:224
msgid "``matches`` — Liste des matchs importés."
msgstr "``matches`` — List of imported matches."

#: ../../source/cli.rst:225
msgid "``positions`` — Liste des positions (limité à 10 par défaut)."
msgstr "``positions`` — List of positions (limited to 10 by default)."

#: ../../source/cli.rst:226
msgid ""
"``stats`` — Statistiques globales (positions, analyses, matchs, parties, "
"coups)."
msgstr ""
"``stats`` — Global statistics (positions, analyses, matches, games, moves)."

#: ../../source/cli.rst:242
msgid "match — Afficher un match"
msgstr "match — Display a match"

#: ../../source/cli.rst:244
msgid "Affiche les positions et analyses d'un match importé."
msgstr "Display positions and analysis of an imported match."

#: ../../source/cli.rst:250
msgid "``--id`` — ID du match à afficher (obligatoire)."
msgstr "``--id`` — Match ID to display (required)."

#: ../../source/cli.rst:251
msgid ""
"``--format`` — Format de sortie: ``json``, ``text`` ou ``summary`` "
"(défaut: ``json``)."
msgstr ""
"``--format`` — Output format: ``json``, ``text`` or ``summary`` "
"(default: ``json``)."

#: ../../source/cli.rst:252
msgid "``--output`` — Fichier de sortie (défaut: sortie standard)."
msgstr "``--output`` — Output file (default: stdout)."

#: ../../source/cli.rst:267
msgid "info — Métadonnées de la base"
msgstr "info — Database metadata"

#: ../../source/cli.rst:269
msgid "Affiche les métadonnées et les statistiques d'une base de données."
msgstr "Display metadata and statistics of a database."

#: ../../source/cli.rst:275
msgid "``--format`` — Format de sortie: ``text`` ou ``json`` (défaut: ``text``)."
msgstr "``--format`` — Output format: ``text`` or ``json`` (default: ``text``)."

#: ../../source/cli.rst:286
msgid "edit — Modifier les métadonnées"
msgstr "edit — Edit metadata"

#: ../../source/cli.rst:288
msgid "Modifie le nom d'utilisateur ou la description d'une base de données."
msgstr "Edit the user name or description of a database."

#: ../../source/cli.rst:294
msgid "``--user`` — Nouveau nom d'utilisateur."
msgstr "``--user`` — New user name."

#: ../../source/cli.rst:295
msgid "``--description`` — Nouvelle description."
msgstr "``--description`` — New description."

#: ../../source/cli.rst:296
msgid "``--clear-user`` — Effacer le nom d'utilisateur."
msgstr "``--clear-user`` — Clear user name."

#: ../../source/cli.rst:297
msgid "``--clear-description`` — Effacer la description."
msgstr "``--clear-description`` — Clear description."

#: ../../source/cli.rst:299
msgid "Au moins une option de modification est requise."
msgstr "At least one edit option is required."

#: ../../source/cli.rst:310
msgid "verify — Vérifier l'intégrité"
msgstr "verify — Verify integrity"

#: ../../source/cli.rst:312
msgid ""
"Vérifie l'intégrité de la base de données et, optionnellement, compare un "
"match avec son fichier source."
msgstr ""
"Verify database integrity and optionally compare a match against its source "
"file."

#: ../../source/cli.rst:319
msgid "``--match`` — ID du match à vérifier."
msgstr "``--match`` — Match ID to verify."

#: ../../source/cli.rst:320
msgid "``--mat`` — Fichier MAT à comparer (utilisé avec ``--match``)."
msgstr "``--mat`` — MAT file to compare against (used with ``--match``)."

#: ../../source/cli.rst:322
msgid ""
"Sans l'option ``--match``, la commande affiche les statistiques générales "
"de la base. Avec ``--match``, elle vérifie les données du match et peut "
"les comparer avec le fichier source original."
msgstr ""
"Without ``--match``, the command displays general database statistics. "
"With ``--match``, it verifies the match data and can compare it against "
"the original source file."

#: ../../source/cli.rst:340
msgid "delete — Supprimer des données"
msgstr "delete — Delete data"

#: ../../source/cli.rst:342
msgid ""
"Supprime un match et toutes les données associées (parties, coups, analyses)."
msgstr ""
"Delete a match and all associated data (games, moves, analyses)."

#: ../../source/cli.rst:348
msgid "``--type`` — Type de suppression: ``match`` (obligatoire)."
msgstr "``--type`` — Delete type: ``match`` (required)."

#: ../../source/cli.rst:349
msgid "``--id`` — ID de l'élément à supprimer (obligatoire)."
msgstr "``--id`` — ID of the item to delete (required)."

#: ../../source/cli.rst:350
msgid "``--confirm`` — Supprimer sans demander de confirmation."
msgstr "``--confirm`` — Delete without asking for confirmation."


#: ../../source/cli.rst:92
msgid "import — Importer des données"
msgstr "import — Importar datos"

#: ../../source/cli.rst:94
msgid "Importe des fichiers de matchs ou de positions dans la base de données."
msgstr "Importa archivos de partidas o de posiciones en la base de datos."

#: ../../source/cli.rst:102
msgid "``--db`` — Chemin de la base de données (obligatoire)."
msgstr "``--db`` — Ruta de la base de datos (obligatorio)."

#: ../../source/cli.rst:103
msgid ""
"``--type`` — Type d'import: ``match``, ``position`` ou ``batch`` "
"(obligatoire)."
msgstr ""
"``--type`` — Tipo de importación: ``match``, ``position`` o ``batch`` "
"(obligatorio)."

#: ../../source/cli.rst:104

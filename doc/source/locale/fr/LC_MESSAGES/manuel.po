#: ../../source/manuel.rst:62
msgid "afficher, ajouter ou modifier des commentaires,"
msgstr ""

#: ../../source/manuel.rst:64
msgid ""
"afficher la liste des matchs importés et naviguer dans les coups d'un "
"match (panneau matchs),"
msgstr ""

#: ../../source/manuel.rst:66
msgid "afficher et gérer les collections de positions (panneau collections),"
msgstr ""

#: ../../source/manuel.rst:68
msgid "afficher et gérer les tournois (panneau tournois),"
msgstr ""

#: ../../source/manuel.rst:70
msgid ""
"calculer l'EPC (Effective Pip Count) d'une position de bearoff (panneau "

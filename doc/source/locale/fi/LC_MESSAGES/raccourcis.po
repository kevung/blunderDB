#: ../../source/raccourcis.rst:4
msgid "Raccourcis clavier"
msgstr "Näppäimistöoikotiet"

#: ../../source/raccourcis.rst:9
msgid "Base de données"
msgstr "Tietokanta"

#: ../../source/raccourcis.rst:1
msgid "Raccourci"
msgstr "Oikotie"

#: ../../source/raccourcis.rst:1
msgid "Action"
msgstr "Toiminto"

#: ../../source/raccourcis.rst:1
msgid "CTRL-N"
msgstr "CTRL-N"

#: ../../source/raccourcis.rst:1
msgid "Créer une nouvelle base de données."
msgstr "Luo uusi tietokanta."

#: ../../source/raccourcis.rst:1
msgid "CTRL-O"
msgstr "CTRL-O"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir une base de données existante."
msgstr "Avaa olemassa oleva tietokanta."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-I"
msgstr "CTRL-SHIFT-I"

#: ../../source/raccourcis.rst:1
msgid "Importer une base de données."
msgstr "Tuo tietokanta."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-S"
msgstr "CTRL-SHIFT-S"

#: ../../source/raccourcis.rst:1
msgid "Exporter la base de données."
msgstr "Vie tietokanta."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Q"
msgstr "CTRL-Q"

#: ../../source/raccourcis.rst:1
msgid "Fermer blunderDB."
msgstr "Sulje blunderDB."

#: ../../source/raccourcis.rst:1
msgid "CTRL-M"
msgstr "CTRL-M"

#: ../../source/raccourcis.rst:1
msgid "Modifier les métadonnées de la base de données."
msgstr "Muokkaa tietokannan metatietoja."

#: ../../source/raccourcis.rst:26
msgid "Position"
msgstr "Asema"

#: ../../source/raccourcis.rst:1
msgid "CTRL-I"
msgstr "CTRL-I"

#: ../../source/raccourcis.rst:1
msgid ""
"Importer une ou plusieurs positions/matchs par fichier (xg, xgp, sgf, "
"mat, txt, bgf)."
msgstr ""
"Tuo yksi tai useampi asema/ottelu tiedostosta (xg, xgp, sgf, mat, txt, "
"bgf)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-F"
msgstr "CTRL-SHIFT-F"

#: ../../source/raccourcis.rst:1
msgid "Importer récursivement un dossier de fichiers de matchs/positions."
msgstr "Tuo ottelu-/asematiedostojen kansio rekursiivisesti."

#: ../../source/raccourcis.rst:1
msgid "CTRL-C"
msgstr "CTRL-C"

#: ../../source/raccourcis.rst:1
msgid "Copier une position dans le presse-papier."
msgstr "Kopioi asema leikepöydälle."

#: ../../source/raccourcis.rst:1
msgid "CTRL-X"
msgstr "CTRL-X"

#: ../../source/raccourcis.rst:1
msgid "Copier l'image du board dans le presse-papier (PNG)."
msgstr "Kopioi laudan kuva leikepöydälle (PNG)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-X CTRL-X"
msgstr "CTRL-X CTRL-X"

#: ../../source/raccourcis.rst:1
msgid "Copier l'image du board avec l'analyse dans le presse-papier (PNG)."
msgstr "Kopioi laudan ja analyysin kuva leikepöydälle (PNG)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-V"
msgstr "CTRL-V"

#: ../../source/raccourcis.rst:1
msgid ""
"Coller une position depuis le presse-papier (détection automatique du "
"format)."
msgstr "Liitä asema leikepöydältä (muoto tunnistetaan automaattisesti)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-S"
msgstr "CTRL-S"

#: ../../source/raccourcis.rst:1
msgid "Enregistrer une position."
msgstr "Tallenna asema."

#: ../../source/raccourcis.rst:1
msgid "CTRL-U"
msgstr "CTRL-U"

#: ../../source/raccourcis.rst:1
msgid "Mettre à jour une position."
msgstr "Päivitä asema."

#: ../../source/raccourcis.rst:1
msgid "Del"
msgstr "Del"

#: ../../source/raccourcis.rst:1
msgid "Supprimer la position courante."
msgstr "Poista nykyinen asema."

#: ../../source/raccourcis.rst:1
msgid "RETOUR ARRIERE"
msgstr "ASKELPALAUTIN"

#: ../../source/raccourcis.rst:1
msgid "Réinitialiser le board, le cube, le score et les dés."
msgstr "Nollaa lauta, tuplauskuutio, tulos ja nopat."

#: ../../source/raccourcis.rst:1
msgid "CTRL-G"
msgstr "CTRL-G"

#: ../../source/raccourcis.rst:1
msgid "Afficher les métadonnées de la position."
msgstr "Näytä aseman metatiedot."

#: ../../source/raccourcis.rst:48
msgid "Navigation"
msgstr "Navigointi"

#: ../../source/raccourcis.rst:1
msgid "CTRL-R"
msgstr "CTRL-R"

#: ../../source/raccourcis.rst:1
msgid "Recharger toutes les positions de la base de données."
msgstr "Lataa kaikki tietokannan asemat uudelleen."

#: ../../source/raccourcis.rst:1
msgid "PageUp, h"
msgstr "PageUp, h"

#: ../../source/raccourcis.rst:1
msgid "Première position / Partie précédente (navigation match)."
msgstr "Ensimmäinen asema / Edellinen peli (ottelunavigointi)."

#: ../../source/raccourcis.rst:1
msgid "GAUCHE, k"
msgstr "VASEN, k"

#: ../../source/raccourcis.rst:1
msgid "Position précédente."
msgstr "Edellinen asema."

#: ../../source/raccourcis.rst:1
msgid "DROITE, j"
msgstr "OIKEA, j"

#: ../../source/raccourcis.rst:1
msgid "Position suivante."
msgstr "Seuraava asema."

#: ../../source/raccourcis.rst:1
msgid "HAUT, k"
msgstr "YLÖS, k"

#: ../../source/raccourcis.rst:1
msgid "Coup précédent (lorsqu'un coup est sélectionné dans l'analyse)."
msgstr "Edellinen siirto (kun analyysissa on valittu siirto)."

#: ../../source/raccourcis.rst:1
msgid "BAS, j"
msgstr "ALAS, j"

#: ../../source/raccourcis.rst:1
msgid "Coup suivant (lorsqu'un coup est sélectionné dans l'analyse)."
msgstr "Seuraava siirto (kun analyysissa on valittu siirto)."

#: ../../source/raccourcis.rst:1
msgid "PageDown, l"
msgstr "PageDown, l"

#: ../../source/raccourcis.rst:1
msgid "Dernière position / Partie suivante (navigation match)."
msgstr "Viimeinen asema / Seuraava peli (ottelunavigointi)."

#: ../../source/raccourcis.rst:1
msgid "r"
msgstr "r"

#: ../../source/raccourcis.rst:1
msgid "Charger une position aléatoire."
msgstr "Lataa satunnainen asema."

#: ../../source/raccourcis.rst:67
msgid "Affichage"
msgstr "Näyttö"

#: ../../source/raccourcis.rst:1
msgid "CTRL-GAUCHE"
msgstr "CTRL-VASEN"

#: ../../source/raccourcis.rst:1
msgid "Orientation du board à gauche."
msgstr "Laudan suunta vasemmalle."

#: ../../source/raccourcis.rst:1
msgid "CTRL-DROITE"
msgstr "CTRL-OIKEA"

#: ../../source/raccourcis.rst:1
msgid "Orientation du board à droite."
msgstr "Laudan suunta oikealle."

#: ../../source/raccourcis.rst:1
msgid "p"
msgstr "p"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le compte de course."
msgstr "Näytä/piilota pip-laskuri."

#: ../../source/raccourcis.rst:81
msgid "Actions"
msgstr "Toiminnot"

#: ../../source/raccourcis.rst:1
msgid "TAB"
msgstr "TAB"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir le panneau de recherche (éditeur de position)."
msgstr "Avaa hakupaneeli (aseman editori)."

#: ../../source/raccourcis.rst:1
msgid "ESPACE"
msgstr "VÄLILYÖNTI"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir la ligne de commande."
msgstr "Avaa komentorivi."

#: ../../source/raccourcis.rst:94
msgid "Outils"
msgstr "Työkalut"

#: ../../source/raccourcis.rst:1
msgid "CTRL-L"
msgstr "CTRL-L"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher l'analyse."
msgstr "Näytä/piilota analyysi."

#: ../../source/raccourcis.rst:1
msgid "CTRL-P"
msgstr "CTRL-P"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher les commentaires."
msgstr "Näytä/piilota kommentit."

#: ../../source/raccourcis.rst:1
msgid "CTRL-K"
msgstr "CTRL-K"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau Anki (répétition espacée)."
msgstr "Näytä/piilota Anki-paneeli (välitoistoharjoittelu)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-F"
msgstr "CTRL-F"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau de recherche."
msgstr "Näytä/piilota hakupaneeli."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Tab"
msgstr "CTRL-Tab"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des matchs."
msgstr "Näytä/piilota ottelupaneeli."

#: ../../source/raccourcis.rst:1
msgid "CTRL-B"
msgstr "CTRL-B"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des collections."
msgstr "Näytä/piilota kokoelmapaneeli."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Y"
msgstr "CTRL-Y"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des tournois."
msgstr "Näytä/piilota turnauspaneeli."

#: ../../source/raccourcis.rst:1
msgid "CTRL-D"
msgstr "CTRL-D"

#: ../../source/raccourcis.rst:1
msgid "Afficher le panneau Stats."
msgstr "Näytä tilastopaneeli."

#: ../../source/raccourcis.rst:1
msgid "CTRL-E"
msgstr "CTRL-E"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau EPC."
msgstr "Näytä/piilota EPC-paneeli."

#: ../../source/raccourcis.rst:1
msgid "?"
msgstr "?"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher l'aide."
msgstr "Näytä/piilota ohje."

#: ../../source/raccourcis.rst:115
msgid "Ligne de commande"
msgstr "Komentorivi"

#: ../../source/raccourcis.rst:1
msgid "HAUT"
msgstr "YLÖS"

#: ../../source/raccourcis.rst:1
msgid "Parcourir l'historique des commandes vers le haut."
msgstr "Selaa komentohistoriaa ylöspäin."

#: ../../source/raccourcis.rst:1
msgid "BAS"
msgstr "ALAS"

#: ../../source/raccourcis.rst:1
msgid "Parcourir l'historique des commandes vers le bas."
msgstr "Selaa komentohistoriaa alaspäin."

#: ../../source/raccourcis.rst:128
msgid "Panneau historique de recherche"
msgstr "Hakuhistoriapaneeli"

#: ../../source/raccourcis.rst:1
msgid "Clic"
msgstr "Napsautus"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner une recherche (afficher la position)."
msgstr "Valitse/poista valinta haulta (näytä asema)."

#: ../../source/raccourcis.rst:1
msgid "Double-clic"
msgstr "Kaksoisnapsautus"

#: ../../source/raccourcis.rst:1
msgid "Exécuter la recherche et fermer le panneau."
msgstr "Suorita haku ja sulje paneeli."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner la recherche précédente (plus récente, au-dessus)."
msgstr "Valitse edellinen haku (uudempi, ylempänä)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner la recherche suivante (plus ancienne, en-dessous)."
msgstr "Valitse seuraava haku (vanhempi, alempana)."

#: ../../source/raccourcis.rst:1
msgid "Esc"
msgstr "Esc"

#: ../../source/raccourcis.rst:1
msgid ""
"Désélectionner la recherche. Si aucune recherche sélectionnée, fermer le "
"panneau."
msgstr ""
"Poista haun valinta. Jos mitään hakua ei ole valittu, sulje paneeli."

#: ../../source/raccourcis.rst:144
msgid "Panneau bibliothèque de filtres"
msgstr "Suodatinkirjastopaneeli"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner un filtre (afficher la position)."
msgstr "Valitse/poista valinta suodattimelta (näytä asema)."

#: ../../source/raccourcis.rst:1
msgid "Exécuter la recherche du filtre."
msgstr "Suorita suodattimen haku."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le filtre précédent (lorsqu'un filtre est sélectionné)."
msgstr "Valitse edellinen suodatin (kun suodatin on valittu)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le filtre suivant (lorsqu'un filtre est sélectionné)."
msgstr "Valitse seuraava suodatin (kun suodatin on valittu)."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner le filtre. Si aucun filtre sélectionné, fermer le panneau."
msgstr ""
"Poista suodattimen valinta. Jos mitään suodatinta ei ole valittu, sulje "
"paneeli."

#: ../../source/raccourcis.rst:160
msgid "Panneau d'analyse"
msgstr "Analyysipaneeli"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner un coup (afficher/cacher les flèches)."
msgstr "Valitse/poista valinta siirrolta (näytä/piilota nuolet)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le coup précédent (lorsqu'un coup est sélectionné)."
msgstr "Valitse edellinen siirto (kun siirto on valittu)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le coup suivant (lorsqu'un coup est sélectionné)."
msgstr "Valitse seuraava siirto (kun siirto on valittu)."

#: ../../source/raccourcis.rst:1
msgid "d"
msgstr "d"

#: ../../source/raccourcis.rst:1
msgid ""
"Basculer entre l'analyse des coups et du cube (navigation match "
"uniquement)."
msgstr ""
"Vaihda nappuloiden ja tuplauskuution analyysin välillä (vain "
"ottelunavigoinnissa)."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner le coup. Si aucun coup sélectionné, fermer le panneau."
msgstr ""
"Poista siirron valinta. Jos mitään siirtoa ei ole valittu, sulje paneeli."

#: ../../source/raccourcis.rst:176
msgid "Panneau des matchs"
msgstr "Ottelupaneeli"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner un match."
msgstr "Valitse ottelu."

#: ../../source/raccourcis.rst:1
msgid "Naviguer dans le match."
msgstr "Navigoi ottelussa."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le match précédent."
msgstr "Valitse edellinen ottelu."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le match suivant."
msgstr "Valitse seuraava ottelu."

#: ../../source/raccourcis.rst:1
msgid "ENTREE"
msgstr "ENTER"

#: ../../source/raccourcis.rst:1
msgid "Charger le match sélectionné."
msgstr "Lataa valittu ottelu."

#: ../../source/raccourcis.rst:1
msgid "Supprimer le match sélectionné."
msgstr "Poista valittu ottelu."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner/fermer le panneau."
msgstr "Poista valinta / sulje paneeli."

#: ../../source/raccourcis.rst:194
msgid "Panneau Anki (répétition espacée)"
msgstr "Anki-paneeli (välitoistoharjoittelu)"

#: ../../source/raccourcis.rst:1
msgid "1"
msgstr "1"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : À revoir (échec, revoir bientôt)."
msgstr "Arvioi: Uudelleen (epäonnistui, kertaa pian)."

#: ../../source/raccourcis.rst:1
msgid "2"
msgstr "2"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Difficile."
msgstr "Arvioi: Vaikea."

#: ../../source/raccourcis.rst:1
msgid "3"
msgstr "3"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Bien."
msgstr "Arvioi: Hyvä."

#: ../../source/raccourcis.rst:1
msgid "4"
msgstr "4"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Facile."
msgstr "Arvioi: Helppo."

#: ../../source/raccourcis.rst:1
msgid "Arrêter la révision et revenir à la liste des paquets (reprise possible)."
msgstr ""
"Lopeta kertaus ja palaa pakkaluetteloon (voidaan jatkaa myöhemmin)."

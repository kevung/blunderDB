#: ../../source/raccourcis.rst:4
msgid "Raccourcis clavier"
msgstr "Συντομεύσεις πληκτρολογίου"

#: ../../source/raccourcis.rst:9
msgid "Base de données"
msgstr "Βάση δεδομένων"

#: ../../source/raccourcis.rst:1
msgid "Raccourci"
msgstr "Συντόμευση"

#: ../../source/raccourcis.rst:1
msgid "Action"
msgstr "Ενέργεια"

#: ../../source/raccourcis.rst:1
msgid "CTRL-N"
msgstr "CTRL-N"

#: ../../source/raccourcis.rst:1
msgid "Créer une nouvelle base de données."
msgstr "Δημιουργία νέας βάσης δεδομένων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-O"
msgstr "CTRL-O"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir une base de données existante."
msgstr "Άνοιγμα υπάρχουσας βάσης δεδομένων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-I"
msgstr "CTRL-SHIFT-I"

#: ../../source/raccourcis.rst:1
msgid "Importer une base de données."
msgstr "Εισαγωγή βάσης δεδομένων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-S"
msgstr "CTRL-SHIFT-S"

#: ../../source/raccourcis.rst:1
msgid "Exporter la base de données."
msgstr "Εξαγωγή της βάσης δεδομένων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Q"
msgstr "CTRL-Q"

#: ../../source/raccourcis.rst:1
msgid "Fermer blunderDB."
msgstr "Κλείσιμο του blunderDB."

#: ../../source/raccourcis.rst:1
msgid "CTRL-M"
msgstr "CTRL-M"

#: ../../source/raccourcis.rst:1
msgid "Modifier les métadonnées de la base de données."
msgstr "Επεξεργασία των μεταδεδομένων της βάσης δεδομένων."

#: ../../source/raccourcis.rst:26
msgid "Position"
msgstr "Θέση"

#: ../../source/raccourcis.rst:1
msgid "CTRL-I"
msgstr "CTRL-I"

#: ../../source/raccourcis.rst:1
msgid ""
"Importer une ou plusieurs positions/matchs par fichier (xg, xgp, sgf, "
"mat, txt, bgf)."
msgstr ""
"Εισαγωγή μίας ή περισσότερων θέσεων/αγώνων από αρχείο (xg, xgp, sgf, mat, "
"txt, bgf)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-F"
msgstr "CTRL-SHIFT-F"

#: ../../source/raccourcis.rst:1
msgid "Importer récursivement un dossier de fichiers de matchs/positions."
msgstr "Αναδρομική εισαγωγή ενός φακέλου αρχείων αγώνων/θέσεων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-C"
msgstr "CTRL-C"

#: ../../source/raccourcis.rst:1
msgid "Copier une position dans le presse-papier."
msgstr "Αντιγραφή θέσης στο πρόχειρο."

#: ../../source/raccourcis.rst:1
msgid "CTRL-X"
msgstr "CTRL-X"

#: ../../source/raccourcis.rst:1
msgid "Copier l'image du board dans le presse-papier (PNG)."
msgstr "Αντιγραφή της εικόνας του ταμπλό στο πρόχειρο (PNG)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-X CTRL-X"
msgstr "CTRL-X CTRL-X"

#: ../../source/raccourcis.rst:1
msgid "Copier l'image du board avec l'analyse dans le presse-papier (PNG)."
msgstr "Αντιγραφή της εικόνας του ταμπλό με την ανάλυση στο πρόχειρο (PNG)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-V"
msgstr "CTRL-V"

#: ../../source/raccourcis.rst:1
msgid ""
"Coller une position depuis le presse-papier (détection automatique du "
"format)."
msgstr "Επικόλληση θέσης από το πρόχειρο (αυτόματη ανίχνευση μορφής)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-S"
msgstr "CTRL-S"

#: ../../source/raccourcis.rst:1
msgid "Enregistrer une position."
msgstr "Αποθήκευση θέσης."

#: ../../source/raccourcis.rst:1
msgid "CTRL-U"
msgstr "CTRL-U"

#: ../../source/raccourcis.rst:1
msgid "Mettre à jour une position."
msgstr "Ενημέρωση θέσης."

#: ../../source/raccourcis.rst:1
msgid "Del"
msgstr "Del"

#: ../../source/raccourcis.rst:1
msgid "Supprimer la position courante."
msgstr "Διαγραφή της τρέχουσας θέσης."

#: ../../source/raccourcis.rst:1
msgid "RETOUR ARRIERE"
msgstr "BACKSPACE"

#: ../../source/raccourcis.rst:1
msgid "Réinitialiser le board, le cube, le score et les dés."
msgstr "Επαναφορά ταμπλό, κύβου, σκορ και ζαριών."

#: ../../source/raccourcis.rst:1
msgid "CTRL-G"
msgstr "CTRL-G"

#: ../../source/raccourcis.rst:1
msgid "Afficher les métadonnées de la position."
msgstr "Εμφάνιση των μεταδεδομένων της θέσης."

#: ../../source/raccourcis.rst:48
msgid "Navigation"
msgstr "Πλοήγηση"

#: ../../source/raccourcis.rst:1
msgid "CTRL-R"
msgstr "CTRL-R"

#: ../../source/raccourcis.rst:1
msgid "Recharger toutes les positions de la base de données."
msgstr "Επαναφόρτωση όλων των θέσεων από τη βάση δεδομένων."

#: ../../source/raccourcis.rst:1
msgid "PageUp, h"
msgstr "PageUp, h"

#: ../../source/raccourcis.rst:1
msgid "Première position / Partie précédente (navigation match)."
msgstr "Πρώτη θέση / Προηγούμενο παιχνίδι (πλοήγηση αγώνα)."

#: ../../source/raccourcis.rst:1
msgid "GAUCHE, k"
msgstr "ΑΡΙΣΤΕΡΑ, k"

#: ../../source/raccourcis.rst:1
msgid "Position précédente."
msgstr "Προηγούμενη θέση."

#: ../../source/raccourcis.rst:1
msgid "DROITE, j"
msgstr "ΔΕΞΙΑ, j"

#: ../../source/raccourcis.rst:1
msgid "Position suivante."
msgstr "Επόμενη θέση."

#: ../../source/raccourcis.rst:1
msgid "HAUT, k"
msgstr "ΠΑΝΩ, k"

#: ../../source/raccourcis.rst:1
msgid "Coup précédent (lorsqu'un coup est sélectionné dans l'analyse)."
msgstr "Προηγούμενη κίνηση (όταν μια κίνηση είναι επιλεγμένη στην ανάλυση)."

#: ../../source/raccourcis.rst:1
msgid "BAS, j"
msgstr "ΚΑΤΩ, j"

#: ../../source/raccourcis.rst:1
msgid "Coup suivant (lorsqu'un coup est sélectionné dans l'analyse)."
msgstr "Επόμενη κίνηση (όταν μια κίνηση είναι επιλεγμένη στην ανάλυση)."

#: ../../source/raccourcis.rst:1
msgid "PageDown, l"
msgstr "PageDown, l"

#: ../../source/raccourcis.rst:1
msgid "Dernière position / Partie suivante (navigation match)."
msgstr "Τελευταία θέση / Επόμενο παιχνίδι (πλοήγηση αγώνα)."

#: ../../source/raccourcis.rst:1
msgid "r"
msgstr "r"

#: ../../source/raccourcis.rst:1
msgid "Charger une position aléatoire."
msgstr "Φόρτωση τυχαίας θέσης."

#: ../../source/raccourcis.rst:67
msgid "Affichage"
msgstr "Εμφάνιση"

#: ../../source/raccourcis.rst:1
msgid "CTRL-GAUCHE"
msgstr "CTRL-ΑΡΙΣΤΕΡΑ"

#: ../../source/raccourcis.rst:1
msgid "Orientation du board à gauche."
msgstr "Προσανατολισμός του ταμπλό προς τα αριστερά."

#: ../../source/raccourcis.rst:1
msgid "CTRL-DROITE"
msgstr "CTRL-ΔΕΞΙΑ"

#: ../../source/raccourcis.rst:1
msgid "Orientation du board à droite."
msgstr "Προσανατολισμός του ταμπλό προς τα δεξιά."

#: ../../source/raccourcis.rst:1
msgid "p"
msgstr "p"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le compte de course."
msgstr "Εμφάνιση/απόκρυψη της μέτρησης πόντων (pipcount)."

#: ../../source/raccourcis.rst:81
msgid "Actions"
msgstr "Ενέργειες"

#: ../../source/raccourcis.rst:1
msgid "TAB"
msgstr "TAB"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir le panneau de recherche (éditeur de position)."
msgstr "Άνοιγμα του πίνακα αναζήτησης (επεξεργαστής θέσης)."

#: ../../source/raccourcis.rst:1
msgid "ESPACE"
msgstr "ΔΙΑΣΤΗΜΑ"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir la ligne de commande."
msgstr "Άνοιγμα της γραμμής εντολών."

#: ../../source/raccourcis.rst:94
msgid "Outils"
msgstr "Εργαλεία"

#: ../../source/raccourcis.rst:1
msgid "CTRL-L"
msgstr "CTRL-L"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher l'analyse."
msgstr "Εμφάνιση/απόκρυψη της ανάλυσης."

#: ../../source/raccourcis.rst:1
msgid "CTRL-P"
msgstr "CTRL-P"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher les commentaires."
msgstr "Εμφάνιση/απόκρυψη των σχολίων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-K"
msgstr "CTRL-K"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau Anki (répétition espacée)."
msgstr "Εμφάνιση/απόκρυψη του πίνακα Anki (επαναληπτική μελέτη με χρονικά διαστήματα)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-F"
msgstr "CTRL-F"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau de recherche."
msgstr "Εμφάνιση/απόκρυψη του πίνακα αναζήτησης."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Tab"
msgstr "CTRL-Tab"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des matchs."
msgstr "Εμφάνιση/απόκρυψη του πίνακα αγώνων."

#: ../../source/raccourcis.rst:1
msgid "CTRL-B"
msgstr "CTRL-B"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des collections."
msgstr "Εμφάνιση/απόκρυψη του πίνακα συλλογών."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Y"
msgstr "CTRL-Y"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des tournois."
msgstr "Εμφάνιση/απόκρυψη του πίνακα τουρνουά."

#: ../../source/raccourcis.rst:1
msgid "CTRL-D"
msgstr "CTRL-D"

#: ../../source/raccourcis.rst:1
msgid "Afficher le panneau Stats."
msgstr "Εμφάνιση του πίνακα στατιστικών."

#: ../../source/raccourcis.rst:1
msgid "CTRL-E"
msgstr "CTRL-E"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau EPC."
msgstr "Εμφάνιση/απόκρυψη του πίνακα EPC."

#: ../../source/raccourcis.rst:1
msgid "?"
msgstr "?"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher l'aide."
msgstr "Εμφάνιση/απόκρυψη της βοήθειας."

#: ../../source/raccourcis.rst:115
msgid "Ligne de commande"
msgstr "Γραμμή εντολών"

#: ../../source/raccourcis.rst:1
msgid "HAUT"
msgstr "ΠΑΝΩ"

#: ../../source/raccourcis.rst:1
msgid "Parcourir l'historique des commandes vers le haut."
msgstr "Περιήγηση στο ιστορικό εντολών προς τα πάνω."

#: ../../source/raccourcis.rst:1
msgid "BAS"
msgstr "ΚΑΤΩ"

#: ../../source/raccourcis.rst:1
msgid "Parcourir l'historique des commandes vers le bas."
msgstr "Περιήγηση στο ιστορικό εντολών προς τα κάτω."

#: ../../source/raccourcis.rst:128
msgid "Panneau historique de recherche"
msgstr "Πίνακας ιστορικού αναζήτησης"

#: ../../source/raccourcis.rst:1
msgid "Clic"
msgstr "Κλικ"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner une recherche (afficher la position)."
msgstr "Επιλογή/αποεπιλογή μιας αναζήτησης (εμφάνιση της θέσης)."

#: ../../source/raccourcis.rst:1
msgid "Double-clic"
msgstr "Διπλό κλικ"

#: ../../source/raccourcis.rst:1
msgid "Exécuter la recherche et fermer le panneau."
msgstr "Εκτέλεση της αναζήτησης και κλείσιμο του πίνακα."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner la recherche précédente (plus récente, au-dessus)."
msgstr "Επιλογή της προηγούμενης αναζήτησης (πιο πρόσφατη, από πάνω)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner la recherche suivante (plus ancienne, en-dessous)."
msgstr "Επιλογή της επόμενης αναζήτησης (παλαιότερη, από κάτω)."

#: ../../source/raccourcis.rst:1
msgid "Esc"
msgstr "Esc"

#: ../../source/raccourcis.rst:1
msgid ""
"Désélectionner la recherche. Si aucune recherche sélectionnée, fermer le "
"panneau."
msgstr ""
"Αποεπιλογή της αναζήτησης. Αν δεν υπάρχει επιλεγμένη αναζήτηση, κλείσιμο "
"του πίνακα."

#: ../../source/raccourcis.rst:144
msgid "Panneau bibliothèque de filtres"
msgstr "Πίνακας βιβλιοθήκης φίλτρων"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner un filtre (afficher la position)."
msgstr "Επιλογή/αποεπιλογή ενός φίλτρου (εμφάνιση της θέσης)."

#: ../../source/raccourcis.rst:1
msgid "Exécuter la recherche du filtre."
msgstr "Εκτέλεση της αναζήτησης του φίλτρου."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le filtre précédent (lorsqu'un filtre est sélectionné)."
msgstr "Επιλογή του προηγούμενου φίλτρου (όταν ένα φίλτρο είναι επιλεγμένο)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le filtre suivant (lorsqu'un filtre est sélectionné)."
msgstr "Επιλογή του επόμενου φίλτρου (όταν ένα φίλτρο είναι επιλεγμένο)."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner le filtre. Si aucun filtre sélectionné, fermer le panneau."
msgstr "Αποεπιλογή του φίλτρου. Αν δεν υπάρχει επιλεγμένο φίλτρο, κλείσιμο του πίνακα."

#: ../../source/raccourcis.rst:160
msgid "Panneau d'analyse"
msgstr "Πίνακας ανάλυσης"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner un coup (afficher/cacher les flèches)."
msgstr "Επιλογή/αποεπιλογή μιας κίνησης (εμφάνιση/απόκρυψη των βελών)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le coup précédent (lorsqu'un coup est sélectionné)."
msgstr "Επιλογή της προηγούμενης κίνησης (όταν μια κίνηση είναι επιλεγμένη)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le coup suivant (lorsqu'un coup est sélectionné)."
msgstr "Επιλογή της επόμενης κίνησης (όταν μια κίνηση είναι επιλεγμένη)."

#: ../../source/raccourcis.rst:1
msgid "d"
msgstr "d"

#: ../../source/raccourcis.rst:1
msgid ""
"Basculer entre l'analyse des coups et du cube (navigation match "
"uniquement)."
msgstr ""
"Εναλλαγή μεταξύ ανάλυσης κινήσεων και κύβου (μόνο σε πλοήγηση αγώνα)."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner le coup. Si aucun coup sélectionné, fermer le panneau."
msgstr "Αποεπιλογή της κίνησης. Αν δεν υπάρχει επιλεγμένη κίνηση, κλείσιμο του πίνακα."

#: ../../source/raccourcis.rst:176
msgid "Panneau des matchs"
msgstr "Πίνακας αγώνων"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner un match."
msgstr "Επιλογή αγώνα."

#: ../../source/raccourcis.rst:1
msgid "Naviguer dans le match."
msgstr "Πλοήγηση μέσα στον αγώνα."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le match précédent."
msgstr "Επιλογή του προηγούμενου αγώνα."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le match suivant."
msgstr "Επιλογή του επόμενου αγώνα."

#: ../../source/raccourcis.rst:1
msgid "ENTREE"
msgstr "ENTER"

#: ../../source/raccourcis.rst:1
msgid "Charger le match sélectionné."
msgstr "Φόρτωση του επιλεγμένου αγώνα."

#: ../../source/raccourcis.rst:1
msgid "Supprimer le match sélectionné."
msgstr "Διαγραφή του επιλεγμένου αγώνα."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner/fermer le panneau."
msgstr "Αποεπιλογή/κλείσιμο του πίνακα."

#: ../../source/raccourcis.rst:194
msgid "Panneau Anki (répétition espacée)"
msgstr "Πίνακας Anki (επαναληπτική μελέτη με χρονικά διαστήματα)"

#: ../../source/raccourcis.rst:1
msgid "1"
msgstr "1"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : À revoir (échec, revoir bientôt)."
msgstr "Αξιολόγηση: Ξανά (αποτυχία, επανάληψη σύντομα)."

#: ../../source/raccourcis.rst:1
msgid "2"
msgstr "2"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Difficile."
msgstr "Αξιολόγηση: Δύσκολο."

#: ../../source/raccourcis.rst:1
msgid "3"
msgstr "3"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Bien."
msgstr "Αξιολόγηση: Καλό."

#: ../../source/raccourcis.rst:1
msgid "4"
msgstr "4"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Facile."
msgstr "Αξιολόγηση: Εύκολο."

#: ../../source/raccourcis.rst:1
msgid "Arrêter la révision et revenir à la liste des paquets (reprise possible)."
msgstr "Διακοπή της επανάληψης και επιστροφή στη λίστα πακέτων (δυνατότητα συνέχισης αργότερα)."

#: ../../source/cli.rst:67
msgid "create — Créer une base de données"
msgstr "create — Δημιουργία βάσης δεδομένων"

#: ../../source/cli.rst:69
msgid ""
"Crée un nouveau fichier de base de données avec des métadonnées "

msgid "Afficher/cacher le panneau Anki (répétition espacée)."
msgstr "Das Anki-Fenster ein-/ausblenden (verteiltes Wiederholen)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-F"
msgstr "STRG-F"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau de recherche."
msgstr "Das Suchfenster ein-/ausblenden."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Tab"
msgstr "STRG-Tab"


msgid "HAUT, k"
msgstr "OBEN, k"

#: ../../source/raccourcis.rst:1
msgid "Coup précédent (lorsqu'un coup est sélectionné dans l'analyse)."
msgstr "Vorheriger Zug (wenn ein Zug in der Analyse ausgewählt ist)."

#: ../../source/raccourcis.rst:1
msgid "BAS, j"
msgstr "UNTEN, j"

#: ../../source/raccourcis.rst:1
msgid "Coup suivant (lorsqu'un coup est sélectionné dans l'analyse)."
msgstr "Nächster Zug (wenn ein Zug in der Analyse ausgewählt ist)."

#: ../../source/raccourcis.rst:1
msgid "PageDown, l"
msgstr "Bild-ab, l"

#: ../../source/raccourcis.rst:1
msgid "Dernière position / Partie suivante (navigation match)."
msgstr "Letzte Position / Nächstes Spiel (Match-Navigation)."

#: ../../source/raccourcis.rst:1
msgid "r"
msgstr "r"

#: ../../source/raccourcis.rst:1
msgid "Charger une position aléatoire."
msgstr "Eine zufällige Position laden."

#: ../../source/raccourcis.rst:67
msgid "Affichage"
msgstr "Anzeige"

#: ../../source/raccourcis.rst:1
msgid "CTRL-GAUCHE"
msgstr "STRG-LINKS"

#: ../../source/raccourcis.rst:1
msgid "Orientation du board à gauche."
msgstr "Board-Ausrichtung nach links."

#: ../../source/raccourcis.rst:1
msgid "CTRL-DROITE"
msgstr "STRG-RECHTS"

#: ../../source/raccourcis.rst:1
msgid "Orientation du board à droite."
msgstr "Board-Ausrichtung nach rechts."

#: ../../source/raccourcis.rst:1
msgid "p"
msgstr "p"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le compte de course."
msgstr "Pipcount ein-/ausblenden."

#: ../../source/raccourcis.rst:81
msgid "Actions"
msgstr "Aktionen"

#: ../../source/raccourcis.rst:1
msgid "TAB"
msgstr "TAB"

#: ../../source/raccourcis.rst:1
msgid "Ouvrir le panneau de recherche (éditeur de position)."
msgstr "Das Suchfenster öffnen (Positionseditor)."

#: ../../source/raccourcis.rst:1
msgid "ESPACE"
msgstr "LEERTASTE"


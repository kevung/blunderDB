msgid "Ouvrir la ligne de commande."
msgstr "Die Befehlszeile öffnen."

#: ../../source/raccourcis.rst:94
msgid "Outils"
msgstr "Werkzeuge"

#: ../../source/raccourcis.rst:1
msgid "CTRL-L"
msgstr "STRG-L"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher l'analyse."
msgstr "Die Analyse ein-/ausblenden."

#: ../../source/raccourcis.rst:1
msgid "CTRL-P"
msgstr "STRG-P"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher les commentaires."
msgstr "Die Kommentare ein-/ausblenden."

#: ../../source/raccourcis.rst:1
msgid "CTRL-K"
msgstr "STRG-K"


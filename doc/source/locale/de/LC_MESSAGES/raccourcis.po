msgid "Évaluer : À revoir (échec, revoir bientôt)."
msgstr "Bewerten: Nochmal (nicht gewusst, bald wiederholen)."

#: ../../source/raccourcis.rst:1
msgid "2"
msgstr "2"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Difficile."
msgstr "Bewerten: Schwer."

#: ../../source/raccourcis.rst:1
msgid "3"
msgstr "3"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Bien."
msgstr "Bewerten: Gut."

#: ../../source/raccourcis.rst:1
msgid "4"
msgstr "4"

#: ../../source/raccourcis.rst:1
msgid "Évaluer : Facile."
msgstr "Bewerten: Einfach."


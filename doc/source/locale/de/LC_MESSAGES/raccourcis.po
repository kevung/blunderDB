msgid "Afficher/cacher le panneau des collections."
msgstr "Das Sammlungen-Fenster ein-/ausblenden."

#: ../../source/raccourcis.rst:1
msgid "CTRL-Y"
msgstr "STRG-Y"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau des tournois."
msgstr "Das Turnier-Fenster ein-/ausblenden."

#: ../../source/raccourcis.rst:1
msgid "CTRL-D"
msgstr "STRG-D"

#: ../../source/raccourcis.rst:1
msgid "Afficher le panneau Stats."
msgstr "Das Statistik-Fenster anzeigen."

#: ../../source/raccourcis.rst:1
msgid "CTRL-E"
msgstr "STRG-E"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher le panneau EPC."
msgstr "Das EPC-Fenster ein-/ausblenden."

#: ../../source/raccourcis.rst:1
msgid "?"
msgstr "?"

#: ../../source/raccourcis.rst:1
msgid "Afficher/cacher l'aide."
msgstr "Die Hilfe ein-/ausblenden."

#: ../../source/raccourcis.rst:115
msgid "Ligne de commande"
msgstr "Befehlszeile"

#: ../../source/raccourcis.rst:1
msgid "HAUT"
msgstr "OBEN"

#: ../../source/raccourcis.rst:1
msgid "Parcourir l'historique des commandes vers le haut."
msgstr "Im Befehlsverlauf nach oben blättern."

#: ../../source/raccourcis.rst:1
msgid "BAS"
msgstr "UNTEN"

#: ../../source/raccourcis.rst:1
msgid "Parcourir l'historique des commandes vers le bas."
msgstr "Im Befehlsverlauf nach unten blättern."

#: ../../source/raccourcis.rst:128
msgid "Panneau historique de recherche"
msgstr "Suchverlauf-Fenster"

#: ../../source/raccourcis.rst:1
msgid "Clic"
msgstr "Klick"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner une recherche (afficher la position)."
msgstr "Eine Suche auswählen/abwählen (Position anzeigen)."

#: ../../source/raccourcis.rst:1
msgid "Double-clic"
msgstr "Doppelklick"

#: ../../source/raccourcis.rst:1
msgid "Exécuter la recherche et fermer le panneau."
msgstr "Die Suche ausführen und das Fenster schließen."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner la recherche précédente (plus récente, au-dessus)."
msgstr "Vorherige Suche auswählen (neuer, darüber)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner la recherche suivante (plus ancienne, en-dessous)."
msgstr "Nächste Suche auswählen (älter, darunter)."

#: ../../source/raccourcis.rst:1
msgid "Esc"
msgstr "Esc"

#: ../../source/raccourcis.rst:1
msgid ""
"Désélectionner la recherche. Si aucune recherche sélectionnée, fermer le "
"panneau."
msgstr ""
"Die Suche abwählen. Wenn keine Suche ausgewählt ist, das Fenster "
"schließen."

#: ../../source/raccourcis.rst:144
msgid "Panneau bibliothèque de filtres"
msgstr "Filterbibliothek-Fenster"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner un filtre (afficher la position)."
msgstr "Einen Filter auswählen/abwählen (Position anzeigen)."

#: ../../source/raccourcis.rst:1
msgid "Exécuter la recherche du filtre."
msgstr "Die Suche des Filters ausführen."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le filtre précédent (lorsqu'un filtre est sélectionné)."
msgstr "Vorherigen Filter auswählen (wenn ein Filter ausgewählt ist)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le filtre suivant (lorsqu'un filtre est sélectionné)."
msgstr "Nächsten Filter auswählen (wenn ein Filter ausgewählt ist)."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner le filtre. Si aucun filtre sélectionné, fermer le panneau."
msgstr ""
"Den Filter abwählen. Wenn kein Filter ausgewählt ist, das Fenster "
"schließen."

#: ../../source/raccourcis.rst:160
msgid "Panneau d'analyse"
msgstr "Analyse-Fenster"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner/désélectionner un coup (afficher/cacher les flèches)."
msgstr "Einen Zug auswählen/abwählen (Pfeile ein-/ausblenden)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le coup précédent (lorsqu'un coup est sélectionné)."
msgstr "Vorherigen Zug auswählen (wenn ein Zug ausgewählt ist)."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le coup suivant (lorsqu'un coup est sélectionné)."
msgstr "Nächsten Zug auswählen (wenn ein Zug ausgewählt ist)."

#: ../../source/raccourcis.rst:1
msgid "d"
msgstr "d"

#: ../../source/raccourcis.rst:1
msgid ""
"Basculer entre l'analyse des coups et du cube (navigation match "
"uniquement)."
msgstr ""
"Zwischen Zug- und Dopplerwürfel-Analyse wechseln (nur Match-Navigation)."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner le coup. Si aucun coup sélectionné, fermer le panneau."
msgstr "Den Zug abwählen. Wenn kein Zug ausgewählt ist, das Fenster schließen."

#: ../../source/raccourcis.rst:176
msgid "Panneau des matchs"
msgstr "Match-Fenster"

#: ../../source/raccourcis.rst:1
msgid "Sélectionner un match."
msgstr "Ein Match auswählen."

#: ../../source/raccourcis.rst:1
msgid "Naviguer dans le match."
msgstr "Im Match navigieren."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le match précédent."
msgstr "Vorheriges Match auswählen."

#: ../../source/raccourcis.rst:1
msgid "Sélectionner le match suivant."
msgstr "Nächstes Match auswählen."

#: ../../source/raccourcis.rst:1
msgid "ENTREE"
msgstr "EINGABE"

#: ../../source/raccourcis.rst:1
msgid "Charger le match sélectionné."
msgstr "Das ausgewählte Match laden."

#: ../../source/raccourcis.rst:1
msgid "Supprimer le match sélectionné."
msgstr "Das ausgewählte Match löschen."

#: ../../source/raccourcis.rst:1
msgid "Désélectionner/fermer le panneau."
msgstr "Abwählen/Fenster schließen."

#: ../../source/raccourcis.rst:194
msgid "Panneau Anki (répétition espacée)"
msgstr "Anki-Fenster (verteiltes Wiederholen)"


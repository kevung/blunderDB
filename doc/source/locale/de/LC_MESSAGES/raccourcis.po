#: ../../source/raccourcis.rst:26
msgid "Position"
msgstr "Position"

#: ../../source/raccourcis.rst:1
msgid "CTRL-I"
msgstr "STRG-I"

#: ../../source/raccourcis.rst:1
msgid ""
"Importer une ou plusieurs positions/matchs par fichier (xg, xgp, sgf, "
"mat, txt, bgf)."
msgstr ""
"Eine oder mehrere Positionen/Matches aus einer Datei importieren (xg, "
"xgp, sgf, mat, txt, bgf)."

#: ../../source/raccourcis.rst:1
msgid "CTRL-SHIFT-F"
msgstr "STRG-UMSCHALT-F"

